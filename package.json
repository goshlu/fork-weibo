{
  "name": "web-extensions",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.28.0",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "cleanup:legacy-storage": "node scripts/cleanup-legacy-api-storage.mjs",
    "prepare": "node scripts/setup-husky.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^9.23.0",
    "@types/node": "^24.5.2",
    "eslint": "^9.23.0",
    "globals": "^16.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.6",
    "prettier": "^3.5.3",
    "turbo": "^2.5.6",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.28.0"
  },
  "lint-staged": {
    "*.{js,mjs,cjs,ts,tsx,json,md}": [
      "prettier --write"
    ],
    "*.{ts,tsx}": [
      "eslint --fix"
    ]
  }
}
