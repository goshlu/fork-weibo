# 数据库配置（保留用于未来扩展）
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/fork_weibo

# Redis 配置（可选，不配置则使用内存缓存）
REDIS_URL=redis://localhost:6379

# JWT 密钥（必须修改为强密码，至少16个字符）
JWT_SECRET=replace-with-a-very-strong-secret

# 服务端口
PORT=4000

# 前端 API 地址
VITE_API_BASE_URL=http://localhost:4000/api

# 文件上传目录
UPLOAD_DIR=apps/api/uploads
DATA_DIR=apps/api/data

# 限流配置
RATE_LIMIT_MAX=120
RATE_LIMIT_WINDOW_MS=60000

# 缓存 TTL
CACHE_TTL_MS=15000

# 信任代理（生产环境反向代理后设为 true）
TRUST_PROXY=false

# CORS 配置（生产环境必须配置）
# 多个域名用逗号分隔，例如：http://localhost:5173,https://example.com
# 不配置则允许所有来源（仅开发环境推荐）
CORS_ORIGIN=http://localhost:5173
